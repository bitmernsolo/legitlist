{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Bitaxe Vendor",
  "type": "object",
  "required": [
    "name",
    "slug",
    "website",
    "region",
    "country",
    "logo",
    "active"
  ],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 80,
      "description": "Public display name of the vendor"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_-]+$",
      "description": "URL-safe identifier, must match filename \u2014 letters, numbers, hyphens, underscores (e.g. \"pivotal-mining\" or \"pivotal_mining\")"
    },
    "website": {
      "type": "string",
      "format": "uri",
      "description": "Full URL of the vendor's website"
    },
    "region": {
      "type": "string",
      "enum": [
        "Europe",
        "North America",
        "South America",
        "Asia Pacific",
        "Middle East",
        "Africa",
        "India"
      ],
      "description": "Geographic region for filtering on the Bitaxe website"
    },
    "country": {
      "type": "string",
      "minLength": 2,
      "maxLength": 60,
      "description": "Country name (e.g. 'USA', 'Germany', 'Australia')"
    },
    "logo": {
      "type": "string",
      "pattern": "^logos/[a-zA-Z0-9_-]+\\.([Pp][Nn][Gg]|[Jj][Pp][Gg]|[Ww][Ee][Bb][Pp])$",
      "description": "Path to logo file relative to repo root (e.g. 'logos/pivotal-mining.png') \u2014 PNG/JPG/WebP, square 400\u00d7400px recommended"
    },
    "description": {
      "type": "string",
      "maxLength": 280,
      "description": "Optional short description (max 280 chars)"
    },
    "active": {
      "type": "boolean",
      "description": "Set to false to hide the vendor without deleting the file"
    },
    "social": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "x": {
          "description": "Full URL to X (Twitter) profile, or empty string to omit",
          "oneOf": [
            {
              "type": "string",
              "format": "uri"
            },
            {
              "type": "string",
              "maxLength": 0
            }
          ]
        },
        "instagram": {
          "description": "Full URL to Instagram profile, or empty string to omit",
          "oneOf": [
            {
              "type": "string",
              "format": "uri"
            },
            {
              "type": "string",
              "maxLength": 0
            }
          ]
        },
        "youtube": {
          "description": "Full URL to YouTube channel, or empty string to omit",
          "oneOf": [
            {
              "type": "string",
              "format": "uri"
            },
            {
              "type": "string",
              "maxLength": 0
            }
          ]
        }
      }
    }
  }
}
